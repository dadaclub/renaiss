# 복사해서 .env.local 로 사용 (커밋 금지 — 실제 값은 여기 넣지 말 것)

# 앨범(SBT) — Renaiss 공개 프로필의 UUID. 이 유저가 "즐겨찾기(showcase)"한 SBT를 이미지째 가져옴.
#   * 비밀 아님(공개 식별자). 없으면 앨범은 목데이터로 폴백.
#   * UUID 찾는 법: Renaiss 로그인 → 프로필 → F12 Network 탭 → `/v0/users/{uuid}` 요청 URL의 UUID.
#     (요청 헤더/쿠키는 절대 복사 금지 — UUID 문자열만.)
RENAISS_SHOWCASE_USER=

# 방명록(Note) — Supabase 프로젝트. 팀원에게 값 요청.
#   * NEXT_PUBLIC_ 접두사라 브라우저에 노출됨(공개 anon 키). 보안은 Supabase RLS 정책으로.
#   * service_role 키는 절대 여기/클라이언트에 넣지 말 것.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# 카드 진열장 — apitcg.com 원피스 카드 이미지 조회. https://apitcg.com/platform 에서 무료 키 발급.
#   * 서버 전용 비밀 키 — NEXT_PUBLIC 접두사 붙이지 말 것(브라우저 노출 금지). API 라우트에서만 사용.
APITCG_API_KEY=

# 실물 카드 시세 — PokemonPriceTracker(포켓몬 전용 + PSA/CGC/BGS 그레이드가). 무료 100/일.
#   * https://www.pokemonpricetracker.com 에서 무료 키 발급. 서버 전용(브라우저 노출 금지).
#   * 없으면 pokemontcg.io(raw) → 스냅샷 순으로 폴백. 원피스는 이 API가 커버 안 함(별도 소스 필요).
POKEMON_PRICE_TRACKER_KEY=
#   * (선택) pokemontcg.io rate limit 상향용. 없어도 동작.
POKEMONTCG_API_KEY=

# (선택) 온체인 조회용 — 현재 미사용. Etherscan/BSCScan 무료 티어는 BSC 조회를 지원하지 않음(유료 필요).
ETHERSCAN_API_KEY=
BSCSCAN_API_KEY=

# 보류/미사용 (방향 전환으로 현재 안 씀)
PSA_API_TOKEN=
PRICE_API_KEY=
ANTHROPIC_API_KEY=
